{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Neuronautix/FAIR.md/schema/fair.schema.json",
  "title": "fair.md YAML front-matter schema",
  "description": "JSON Schema (draft 2020-12) for the YAML front matter of a fair.md file conforming to the fair.md specification v0.2. Apply to the parsed YAML object (the front-matter block between the --- delimiters).",
  "type": "object",
  "required": [
    "fair_md_version",
    "title",
    "description",
    "identifiers",
    "maintainers",
    "license",
    "data_resources",
    "vocabularies",
    "fair_assessment",
    "companions",
    "maturity",
    "last_reviewed"
  ],
  "additionalProperties": true,
  "properties": {
    "fair_md_version": {
      "type": "string",
      "description": "Version of the fair.md specification this file conforms to. '0.1' remains accepted for backward compatibility.",
      "enum": ["0.1", "0.2"]
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Short, human-readable name for the repository or dataset."
    },
    "description": {
      "type": "string",
      "minLength": 1,
      "description": "Paragraph-length description of what the repository contains."
    },
    "identifiers": {
      "type": "object",
      "required": ["repository", "homepage", "canonical", "doi"],
      "additionalProperties": false,
      "properties": {
        "repository": {
          "type": "string",
          "format": "uri",
          "description": "URL of the source code or data repository."
        },
        "homepage": {
          "type": "string",
          "format": "uri",
          "description": "Canonical homepage of the project."
        },
        "canonical": {
          "type": "string",
          "format": "uri",
          "description": "Stable URL where this fair.md file is served."
        },
        "doi": {
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "description": "DOI if minted, e.g. '10.5281/zenodo.1234567'."
            },
            {
              "type": "null",
              "description": "null if no DOI has been minted yet."
            }
          ]
        }
      }
    },
    "maintainers": {
      "type": "array",
      "minItems": 1,
      "description": "Accountable people for this repository.",
      "items": {
        "type": "object",
        "required": ["name", "role"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "description": "Full name of the maintainer."
          },
          "role": {
            "type": "string",
            "minLength": 1,
            "description": "Role(s) with respect to the repository."
          },
          "orcid": {
            "type": "string",
            "pattern": "^[0-9]{4}-[0-9]{4}-[0-9]{4}-[0-9]{3}[0-9X]$",
            "description": "ORCID iD in the format 0000-0000-0000-000X."
          },
          "org": {
            "type": "string",
            "description": "Institutional affiliation."
          }
        }
      }
    },
    "license": {
      "type": "object",
      "required": ["content", "code"],
      "additionalProperties": false,
      "properties": {
        "content": {
          "type": "string",
          "minLength": 1,
          "description": "SPDX license identifier for content/data, or 'unspecified'."
        },
        "code": {
          "type": "string",
          "minLength": 1,
          "description": "SPDX license identifier for code, or 'unspecified'."
        }
      }
    },
    "data_resources": {
      "type": "array",
      "minItems": 1,
      "description": "The FAIR objects this manifest covers.",
      "items": {
        "type": "object",
        "required": ["id", "path", "type"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-zA-Z0-9-_]+$",
            "description": "Short identifier for this resource (no spaces)."
          },
          "path": {
            "type": "string",
            "pattern": "^/",
            "description": "Root path of this resource within the repository or site."
          },
          "type": {
            "type": "string",
            "minLength": 1,
            "description": "Human-readable description of the resource type and format."
          },
          "topics": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Topical keywords for this resource."
          },
          "count": {
            "oneOf": [
              {
                "type": "integer",
                "minimum": 0,
                "description": "Number of items in the collection."
              },
              {
                "type": "null"
              }
            ]
          }
        }
      }
    },
    "vocabularies": {
      "type": "array",
      "description": "Controlled vocabularies, ontologies, and data standards referenced.",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "fair_assessment": {
      "type": "object",
      "required": ["findable", "accessible", "interoperable", "reusable"],
      "additionalProperties": false,
      "description": "FAIR self-assessment grouped by principle.",
      "properties": {
        "findable": {
          "type": "object",
          "required": [
            "F1_globally_unique_persistent_id",
            "F2_rich_metadata",
            "F3_metadata_references_data_id",
            "F4_indexed_searchable"
          ],
          "additionalProperties": false,
          "properties": {
            "F1_globally_unique_persistent_id": {
              "$ref": "#/$defs/fairStatus"
            },
            "F2_rich_metadata": {
              "$ref": "#/$defs/fairStatus"
            },
            "F3_metadata_references_data_id": {
              "$ref": "#/$defs/fairStatus"
            },
            "F4_indexed_searchable": {
              "$ref": "#/$defs/fairStatus"
            }
          }
        },
        "accessible": {
          "type": "object",
          "required": [
            "A1_retrievable_by_id_open_protocol",
            "A1.1_protocol_open_free",
            "A1.2_auth_where_needed",
            "A2_metadata_persist_beyond_data"
          ],
          "additionalProperties": false,
          "properties": {
            "A1_retrievable_by_id_open_protocol": {
              "$ref": "#/$defs/fairStatus"
            },
            "A1.1_protocol_open_free": {
              "$ref": "#/$defs/fairStatus"
            },
            "A1.2_auth_where_needed": {
              "$ref": "#/$defs/fairStatus"
            },
            "A2_metadata_persist_beyond_data": {
              "$ref": "#/$defs/fairStatus"
            }
          }
        },
        "interoperable": {
          "type": "object",
          "required": [
            "I1_formal_accessible_knowledge_representation",
            "I2_FAIR_vocabularies",
            "I3_qualified_references"
          ],
          "additionalProperties": false,
          "properties": {
            "I1_formal_accessible_knowledge_representation": {
              "$ref": "#/$defs/fairStatus"
            },
            "I2_FAIR_vocabularies": {
              "$ref": "#/$defs/fairStatus"
            },
            "I3_qualified_references": {
              "$ref": "#/$defs/fairStatus"
            }
          }
        },
        "reusable": {
          "type": "object",
          "required": [
            "R1_plurality_of_attributes",
            "R1.1_clear_data_usage_license",
            "R1.2_detailed_provenance",
            "R1.3_domain_community_standards"
          ],
          "additionalProperties": false,
          "properties": {
            "R1_plurality_of_attributes": {
              "$ref": "#/$defs/fairStatus"
            },
            "R1.1_clear_data_usage_license": {
              "$ref": "#/$defs/fairStatus"
            },
            "R1.2_detailed_provenance": {
              "$ref": "#/$defs/fairStatus"
            },
            "R1.3_domain_community_standards": {
              "$ref": "#/$defs/fairStatus"
            }
          }
        }
      }
    },
    "companions": {
      "type": "object",
      "additionalProperties": true,
      "description": "Paths to companion machine-readable artifacts, or null if absent.",
      "properties": {
        "trust": {
          "$ref": "#/$defs/companionPath"
        },
        "sitemap": {
          "$ref": "#/$defs/companionPath"
        },
        "robots": {
          "$ref": "#/$defs/companionPath"
        },
        "citation_cff": {
          "$ref": "#/$defs/companionPath"
        },
        "codemeta": {
          "$ref": "#/$defs/companionPath"
        },
        "ro_crate": {
          "$ref": "#/$defs/companionPath"
        }
      }
    },
    "maturity": {
      "type": "string",
      "enum": ["prototype", "beta", "stable"],
      "description": "Maturity level of this repository's FAIR posture."
    },
    "last_reviewed": {
      "type": "string",
      "format": "date",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
      "description": "ISO 8601 date (YYYY-MM-DD) of the last honest review."
    }
  },
  "$defs": {
    "fairStatus": {
      "type": "string",
      "enum": ["yes", "partial", "planned", "no", "n/a"],
      "description": "FAIR self-assessment status: yes | partial | planned | no | n/a"
    },
    "companionPath": {
      "oneOf": [
        {
          "type": "string",
          "pattern": "^(/|https?://)",
          "description": "Root-relative path (e.g. '/trust.md') or absolute http(s) URL to the companion artifact."
        },
        {
          "type": "null",
          "description": "null if the companion artifact does not exist yet."
        }
      ]
    }
  }
}
